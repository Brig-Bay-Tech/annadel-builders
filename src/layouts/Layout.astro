---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  transparentHeader?: boolean;
}

const { title, description = 'Annadel Builders Inc. - Sonoma County fine home builders focused on fine craftsmanship and sustainability.', transparentHeader = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body class="font-montserrat text-text">
  <header class={`w-full z-50 ${transparentHeader ? 'absolute top-0 left-0' : 'relative bg-primary'}`}>
    <div class="max-w-[1240px] mx-auto flex items-center justify-between px-[50px] h-[170px] max-lg:h-auto max-lg:py-4 max-lg:px-4">
      <!-- Logo -->
      <a href="/" class="block">
        <img src="/images/Annadel-Whitecrop.png" alt="Annadel Builders Inc." class="max-w-[360px] max-sm:max-w-[190px] h-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0 text-white text-[16px] uppercase tracking-wide" id="desktop-nav">
        <a href="/about/" class="px-[11px] py-2 hover:opacity-80 transition">About</a>
        <div class="relative group">
          <button class="px-[11px] py-2 hover:opacity-80 transition flex items-center gap-1 uppercase">
            Portfolio <svg class="w-3 h-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
          </button>
          <div class="absolute top-full left-0 bg-white/20 backdrop-blur-sm border border-transparent min-w-[200px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/portfolio/" class="block px-4 py-2 text-white text-[12px] tracking-[.6px] leading-[1.2] hover:bg-white/10">COMPLETED</a>
            <a href="/portfolio/in-progress/" class="block px-4 py-2 text-white text-[12px] tracking-[.6px] leading-[1.2] hover:bg-white/10">IN-PROGRESS</a>
          </div>
        </div>
        <div class="relative group">
          <button class="px-[11px] py-2 hover:opacity-80 transition flex items-center gap-1 uppercase">
            Services <svg class="w-3 h-3 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
          </button>
          <div class="absolute top-full left-0 bg-white/20 backdrop-blur-sm border border-transparent min-w-[340px] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/services/construction-management-in-sonoma-county/" class="block px-4 py-2 text-white text-[12px] tracking-[.6px] leading-[1.2] hover:bg-white/10">CONSTRUCTION MANAGEMENT IN SONOMA COUNTY</a>
            <a href="/services/sonoma-county-building-estate-development/" class="block px-4 py-2 text-white text-[12px] tracking-[.6px] leading-[1.2] hover:bg-white/10">SONOMA COUNTY BUILDING & DEVELOPMENT</a>
            <a href="/services/fire-rebuilds-in-sonoma-county/" class="block px-4 py-2 text-white text-[12px] tracking-[.6px] leading-[1.2] hover:bg-white/10">FIRE REBUILDS IN SONOMA COUNTY</a>
          </div>
        </div>
        <a href="/publications/" class="px-[11px] py-2 hover:opacity-80 transition">Publications</a>
        <a href="/contact/" class="px-[11px] py-2 hover:opacity-80 transition">Contact</a>
        <a href="https://www.houzz.com/professionals/home-builders/annadel-builders-pfvwus-pf~1385764798" target="_blank" rel="noopener" class="px-[11px] py-2">
          <img src="/images/Untitled-design-9-1-e1740772482962.png" alt="Houzz" class="w-[17px] h-[17px]" />
        </a>
        <a href="https://www.instagram.com/annadelbuildersinc/" target="_blank" rel="noopener" class="px-[11px] py-2">
          <img src="/images/insta-1-e1740772495267.png" alt="Instagram" class="w-[17px] h-[17px]" />
        </a>
      </nav>

      <!-- Mobile Menu Toggle -->
      <button class="lg:hidden text-white text-2xl" id="mobile-menu-toggle" aria-label="Mobile Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div class="hidden lg:hidden bg-primary text-white" id="mobile-menu">
      <nav class="flex flex-col px-4 py-4 text-[17px]">
        <a href="/about/" class="py-2 border-b border-white/10">ABOUT</a>
        <details class="border-b border-white/10">
          <summary class="py-2 cursor-pointer">PORTFOLIO</summary>
          <a href="/portfolio/" class="block py-2 pl-4 text-sm">COMPLETED</a>
          <a href="/portfolio/in-progress/" class="block py-2 pl-4 text-sm">IN-PROGRESS</a>
        </details>
        <details class="border-b border-white/10">
          <summary class="py-2 cursor-pointer">SERVICES</summary>
          <a href="/services/construction-management-in-sonoma-county/" class="block py-2 pl-4 text-sm">CONSTRUCTION MANAGEMENT</a>
          <a href="/services/sonoma-county-building-estate-development/" class="block py-2 pl-4 text-sm">BUILDING & DEVELOPMENT</a>
          <a href="/services/fire-rebuilds-in-sonoma-county/" class="block py-2 pl-4 text-sm">FIRE REBUILDS</a>
        </details>
        <a href="/publications/" class="py-2 border-b border-white/10">PUBLICATIONS</a>
        <a href="/contact/" class="py-2 border-b border-white/10">CONTACT</a>
        <div class="flex gap-4 py-4">
          <a href="https://www.houzz.com/professionals/home-builders/annadel-builders-pfvwus-pf~1385764798" target="_blank" rel="noopener">HOUZZ</a>
          <a href="https://www.instagram.com/annadelbuildersinc/" target="_blank" rel="noopener">INSTAGRAM</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-primary text-white">
    <div id="footer-widgets" class="py-12">
      <div class="max-w-[1140px] mx-auto px-4">
        <p class="font-bold">Annadel Builders Inc.</p>
        <p class="mt-2">4010 Montecito Avenue<br />Santa Rosa, California 95409<br />Phone: <a href="tel:7075796282" class="hover:text-gray-300">707-579-6282</a></p>
        <p class="mt-2"><a href="/contact/" class="hover:text-gray-300">Contact us</a> · <a href="/privacy-policy/" class="hover:text-gray-300">Privacy Policy</a></p>
      </div>
    </div>
    <div class="bg-secondary py-4">
      <div class="max-w-[1140px] mx-auto px-4 text-center text-[15px]">
        Copyright 2026 - Annadel Builders Inc.
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
