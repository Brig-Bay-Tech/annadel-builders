---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Layout title="Sonoma Contemporary Home – Annadel Builders Inc." description="Sonoma Contemporary Home - A custom home project by Annadel Builders in Sonoma County.">
  <PageHeader title="Sonoma Contemporary Home" bgImage="/images/059_Annadel_Final-XL-e1735322733993.jpg" />
  <section class="max-w-[1140px] mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <img src="/images/059_Annadel_Final-XL-e1735322733993.jpg" alt="Sonoma Contemporary Home" class="w-full h-auto mb-8" loading="lazy" />
      <p class="mt-4">This project showcases the quality craftsmanship and attention to detail that defines Annadel Builders. <a href="/contact/" class="text-teal hover:underline">Contact us</a> to discuss your project.</p>
      <p class="mt-8"><a href="/portfolio/" class="text-teal hover:underline">&#8592; Back to Portfolio</a></p>
    </div>
  </section>
</Layout>
