---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Publications – Annadel Builders Inc." description="Annadel Builders featured publications and magazine articles.">
  <PageHeader title="Publications" bgImage="/images/Sonoma-Dwelling-by-Annadel-Builders-scaled-1.jpg" />

  <section class="max-w-[1140px] mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="text-center">
        <img src="/images/Annadel-Mag-1.png" alt="Annadel Builders Magazine Feature" class="w-full h-auto shadow-lg" loading="lazy" />
      </div>
      <div class="text-center">
        <img src="/images/Annadel-Mag-2.png" alt="Annadel Builders Magazine Feature" class="w-full h-auto shadow-lg" loading="lazy" />
      </div>
      <div class="text-center">
        <img src="/images/Cover_June_July_23.jpg" alt="Magazine Cover Feature" class="w-full h-auto shadow-lg" loading="lazy" />
      </div>
      <div class="text-center">
        <img src="/images/Anadel-Article.png" alt="Annadel Builders Article" class="w-full h-auto shadow-lg" loading="lazy" />
      </div>
      <div class="text-center">
        <img src="/images/PFAIA.jpg" alt="Annadel Builders Publication" class="w-full h-auto shadow-lg" loading="lazy" />
      </div>
    </div>
  </section>
</Layout>
