---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Privacy Policy – Annadel Builders Inc.">
  <PageHeader title="Privacy Policy" />
  <section class="max-w-container mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto prose">
      <p>Your privacy is important to us. This privacy policy explains how Annadel Builders Inc. collects, uses, and protects your personal information.</p>
      <h2>Information We Collect</h2>
      <p>We may collect personal information such as your name, email address, phone number, and project details when you contact us through our website or by phone.</p>
      <h2>How We Use Your Information</h2>
      <p>We use the information we collect to respond to your inquiries, provide estimates, and communicate about your project.</p>
      <h2>Contact Us</h2>
      <p>If you have questions about this privacy policy, contact us at <a href="tel:7075796282" class="text-teal">(707) 579-6282</a> or <a href="mailto:info@annadelbuildersinc.com" class="text-teal">info@annadelbuildersinc.com</a>.</p>
    </div>
  </section>
</Layout>
