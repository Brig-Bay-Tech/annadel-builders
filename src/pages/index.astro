---
import Layout from '../layouts/Layout.astro';

const slides = [
  { image: '/images/Kamen-Residence-Revised-WEB8-scaled-1.jpg', heading: 'Building with Intention.' },
  { image: '/images/38-MAK-Thomas-Exterior-110.jpg', heading: 'Fine Home Builders in Sonoma & Napa County.' },
  { image: '/images/Title-slider-3-annadel.jpg', heading: 'Diligent. Knowledgeable. Dedicated.' },
  { image: '/images/65-MAK-Thomas-Living-187.jpg', heading: 'Quality. Sustainability.' },
  { image: '/images/60-MAK-Thomas-Living-077.jpg', heading: 'Vision Becomes Life.' },
];
---

<Layout title="Annadel Builders Inc." transparentHeader={true}>
  <!-- Hero Slider -->
  <section class="relative h-[1000px] max-md:h-[500px] overflow-hidden" id="hero-slider">
    {slides.map((slide, i) => (
      <div class={`slide absolute inset-0 transition-opacity duration-1000 ${i === 0 ? 'opacity-100' : 'opacity-0'}`} data-index={i}>
        <div class="absolute inset-0 bg-cover bg-center animate-ken-burns" style={`background-image: url('${slide.image}')`}></div>
        <div class="absolute inset-0 bg-black/25"></div>
        <div class="absolute inset-0 flex items-center justify-center text-center px-4">
          <h1 class="text-white font-light text-[90px] max-lg:text-[75px] max-md:text-[40px] font-montserrat" style="text-shadow: 0px 0px 15px rgba(0,0,0,0.3)">
            {slide.heading}
          </h1>
        </div>
      </div>
    ))}
    <!-- Arrows -->
    <button class="absolute left-6 top-1/2 -translate-y-1/2 text-white/80 hover:text-white z-10 transition" id="prev-slide" aria-label="Previous">
      <svg class="w-10 h-10" viewBox="0 0 1000 1000" fill="currentColor"><path d="M646 125C629 125 613 133 604 142L308 442C296 454 292 471 292 487 292 504 296 521 308 533L604 854C617 867 629 875 646 875 663 875 679 871 692 858 704 846 713 829 713 812 713 796 708 779 692 767L438 487 692 225C700 217 708 204 708 187 708 171 704 154 692 142 675 129 663 125 646 125Z"/></svg>
    </button>
    <button class="absolute right-6 top-1/2 -translate-y-1/2 text-white/80 hover:text-white z-10 transition" id="next-slide" aria-label="Next">
      <svg class="w-10 h-10" viewBox="0 0 1000 1000" fill="currentColor"><path d="M696 533C708 521 713 504 713 487 713 471 708 454 696 446L400 146C388 133 375 125 354 125 338 125 325 129 313 142 300 154 292 171 292 187 292 204 296 221 308 233L563 492 304 771C292 783 288 800 288 817 288 833 296 850 308 863 321 871 338 875 354 875 371 875 388 867 400 854L696 533Z"/></svg>
    </button>
  </section>

  <!-- Our Mission -->
  <section class="py-0">
    <div class="h-[50px]"></div>
    <div class="max-w-container mx-auto px-4 text-center">
      <h2 class="text-primary">Our Mission</h2>
      <p class="px-4 md:px-[100px] mt-4">To build finely crafted sustainable homes. To employ conscientious quality oriented people. To improve the environment of our employees, our clients, and our community through our work as builders. To balance work flow with highly dependable service. To continually strive for excellence through training and dedication.</p>
      <div class="w-[71%] mx-auto border-t-[3px] border-muted my-[15px]"></div>
    </div>
  </section>

  <!-- Sonoma & Napa County Fine Home Builders -->
  <section>
    <div class="h-[50px] max-md:h-0"></div>
    <div class="max-w-container mx-auto px-4 text-center">
      <h2 class="text-primary">Sonoma &amp; Napa County Fine Home Builders</h2>
    </div>
  </section>

  <section class="max-w-container mx-auto px-4 md:px-[150px] text-center text-[18px] mt-6 max-md:px-4">
    <p><strong>Trust. Value. Quality.</strong> At Annadel Builders, Inc., our professional team of Sonoma County fine home builders focuses on fine craftsmanship and sustainability as a core result. We are pleased to serve Napa, Sonoma, and Marin Counties, where the environment lends to innovative and beautiful home design and building. The intentionality and elegance of the projects we undertake is not only seen, but felt. We invite you to discover what makes Annadel Builders unique.</p>
    <div class="w-[71%] mx-auto border-t-[3px] border-muted my-[15px]"></div>
  </section>

  <!-- Sustainability, Stewardship -->
  <section class="max-w-container mx-auto">
    <div class="flex flex-col md:flex-row">
      <div class="md:w-1/2 flex items-center justify-center p-4">
        <img src="/images/Anna-home-page.jpg" alt="Luxury custom home construction Sonoma County" class="w-full h-auto" loading="lazy" />
      </div>
      <div class="md:w-1/2 p-6 md:p-10">
        <h2 class="text-muted text-[34px]">Sustainability, Stewardship.</h2>
        <div class="mt-4 space-y-4">
          <p>At Annadel Builders, we take a two-fold approach to stewardship:</p>
          <p><strong>Stewardship of client resources</strong> – Our respect for our clients is demonstrated in the care and intentionality shown in each step of the decision-making process. With stewardship as our focus, we provide cost estimate and value engineering services throughout the lifecycle of a project, and diligently research and allocate materials throughout the process. We also proudly advocate for our clients in obtaining applicable county and city permits, drawing from years of experience in that process.</p>
          <p><strong>Stewardship of the environment</strong> – As LEED AP credential holders (Leadership in Energy &amp; Environmental Design), our team has demonstrated an ongoing commitment to leadership and innovation in the area of green building and design. We have a vested interest in the sustainability of our projects and are passionate about the proper management of natural resources.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Start your Journey -->
  <section class="max-w-container mx-auto">
    <div class="flex flex-col md:flex-row">
      <div class="md:w-1/2 p-6 md:p-10">
        <h2 class="text-muted text-[34px] max-md:text-center">Start your Journey</h2>
        <p class="mt-4 max-md:text-center">Building a home is an exciting journey—and Annadel Builders is outfitted with the experience and excellence of workmanship necessary to walk through this process with you. In addition to our own field crews and project management team, we include a host of Napa and Sonoma County subcontractors committed to achieving exceptional results tailored to the specifications of each and every homeowner.</p>
      </div>
      <div class="md:w-1/2 flex items-center justify-center p-4">
        <img src="/images/Anna-home-page2.png" alt="Luxury custom home construction Sonoma County" class="w-full h-auto" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-0">
    <div class="h-[50px]"></div>
    <div class="max-w-container mx-auto px-4 md:px-[150px] text-center max-md:px-4">
      <p><strong>Learn more about our fine home builders and the vision that distinguishes us: <a href="/contact/" class="text-teal hover:underline">Contact Annadel Builders, Inc.</a> today at <a href="tel:7075796282" class="text-teal hover:underline">(707) 579-6282</a> or <a href="mailto:info@annadelbuildersinc.com" class="text-teal hover:underline">info@annadelbuildersinc.com</a> to generate an estimate or to arrange a meeting.</strong></p>
    </div>
  </section>

  <div class="h-16"></div>
</Layout>

<style>
  @keyframes kenBurns {
    0% { transform: scale(1); }
    100% { transform: scale(1.15); }
  }
  .animate-ken-burns {
    animation: kenBurns 5.4s ease-in-out forwards;
  }
  .slide.opacity-100 .animate-ken-burns {
    animation: kenBurns 5.4s ease-in-out forwards;
  }
</style>

<script>
  let current = 0;
  const slides = document.querySelectorAll('#hero-slider .slide');
  const total = slides.length;
  let interval: ReturnType<typeof setInterval>;

  function showSlide(n: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).classList.toggle('opacity-100', i === n);
      (s as HTMLElement).classList.toggle('opacity-0', i !== n);
    });
    current = n;
  }

  function next() { showSlide((current + 1) % total); }
  function prev() { showSlide((current - 1 + total) % total); }

  function startAuto() { interval = setInterval(next, 4500); }
  function resetAuto() { clearInterval(interval); startAuto(); }

  document.getElementById('next-slide')?.addEventListener('click', () => { next(); resetAuto(); });
  document.getElementById('prev-slide')?.addEventListener('click', () => { prev(); resetAuto(); });
  startAuto();
</script>
