<Layout title="Chalk Hill Estate – Annadel Builders Inc." description="Chalk Hill Estate - A custom home project by Annadel Builders in Sonoma County.">
  <PageHeader title="Chalk Hill Estate" bgImage="/images/Chalk-Hill-Cover-48-MAK-Thomas-Exterior-217-1200x800-1.jpg" />
  <section class="max-w-[1140px] mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <img src="/images/Chalk-Hill-Cover-48-MAK-Thomas-Exterior-217-1200x800-1.jpg" alt="Chalk Hill Estate" class="w-full h-auto mb-8" loading="lazy" />
      <p class="mt-4">This project showcases the quality craftsmanship and attention to detail that defines Annadel Builders. <a href="/contact/" class="text-teal hover:underline">Contact us</a> to discuss your project.</p>
      <p class="mt-8"><a href="/portfolio/" class="text-teal hover:underline">&#8592; Back to Portfolio</a></p>
    </div>
  </section>
</Layout>
