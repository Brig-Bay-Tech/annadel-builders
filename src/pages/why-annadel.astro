---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Why Annadel – Annadel Builders Inc." description="Discover what makes Annadel Builders unique - commitment to environmentally conscious methods and beautiful home design.">
  <PageHeader title="Why Annadel" bgImage="/images/Sonoma-Dwelling-by-Annadel-Builders-scaled-1.jpg" />

  <section class="max-w-[1140px] mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-lg">Partnering with our clients to make their visions come to life is a privilege. Napa, Marin, and Sonoma counties lead the world in lending themselves to outstandingly beautiful home design and construction, and at Annadel Builders, Inc., we are committed to using environmentally conscious methods.</p>
    </div>
  </section>
</Layout>
