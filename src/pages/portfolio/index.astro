---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';

const projects = [
  { title: 'Sonoma Vineyard Estate', image: '/images/Sonoma-Dwelling-by-Annadel-Builders-scaled-1-e1735322420166.jpg', href: '/sonoma-vineyard-estate/' },
  { title: 'Sonoma Family Hilltop Retreat', image: '/images/Sonoma_Ridge_Zeitgeist_FullRes-30-of-48-3-1200x799-1.jpg', href: '/sonoma-family-hilltop-retreat/' },
  { title: 'Santa Rosa Foothills Fire Rebuild', image: '/images/Santa-Rosa-Foothills-Fire-Rebuild-sonoma-3-1-1200x800-1.png', href: '/santa-rosa-foothills-fire-rebuild/' },
  { title: 'Sonoma Estate', image: '/images/sonoma-estate-scaled-1200x900-1-e1735323273260.jpg', href: '/sonoma-estate/' },
  { title: 'Sebastopol Farm House', image: '/images/bTkiriTQ-1200x799-1.jpg', href: '/sebastopol-farm-house/' },
  { title: 'Chalk Hill Estate', image: '/images/Chalk-Hill-Cover-48-MAK-Thomas-Exterior-217-1200x800-1.jpg', href: '/chalk-hill-estate/' },
  { title: 'Silverado Trail Farm House', image: '/images/MG_0127-1-e1714593196580-1200x800-1-e1735323701494.jpg', href: '/silverado-trail-farm-house/' },
  { title: 'Sonoma Contemporary Home', image: '/images/059_Annadel_Final-XL-e1735322733993.jpg', href: '/sonoma-contemporary-home/' },
  { title: 'Maacama', image: '/images/DroneFavEdit2.jpg', href: '/maacama/' },
  { title: 'Lucky Dog', image: '/images/PFProcoreEdit2-1-scaled-1.jpg', href: '/portfolio/lucky-dog/' },
];
---

<Layout title="Portfolio – Annadel Builders Inc." description="View completed custom home projects by Annadel Builders in Sonoma and Napa County.">
  <PageHeader title="Completed Projects" bgImage="/images/Sonoma-Dwelling-by-Annadel-Builders-scaled-1.jpg" />

  <section class="max-w-[1140px] mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map(project => (
        <a href={project.href} class="group block overflow-hidden">
          <div class="relative overflow-hidden aspect-[4/3]">
            <img src={project.image} alt={project.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all duration-300 flex items-center justify-center">
              <span class="text-white text-lg font-light opacity-0 group-hover:opacity-100 transition-opacity duration-300">{project.title}</span>
            </div>
          </div>
          <h3 class="mt-3 text-primary text-center font-normal text-[18px]">{project.title}</h3>
        </a>
      ))}
    </div>
  </section>
</Layout>
