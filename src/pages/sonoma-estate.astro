---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Layout title="Sonoma Estate – Annadel Builders Inc." description="Sonoma Estate - A custom home project by Annadel Builders in Sonoma County.">
  <PageHeader title="Sonoma Estate" bgImage="/images/sonoma-estate-scaled-1200x900-1-e1735323273260.jpg" />
  <section class="max-w-container mx-auto px-4 py-16">
    <div class="max-w-3xl mx-auto text-center">
      <img src="/images/sonoma-estate-scaled-1200x900-1-e1735323273260.jpg" alt="Sonoma Estate" class="w-full h-auto mb-8" loading="lazy" />
      <p class="mt-4">This project showcases the quality craftsmanship and attention to detail that defines Annadel Builders. <a href="/contact/" class="text-teal hover:underline">Contact us</a> to discuss your project.</p>
      <p class="mt-8"><a href="/portfolio/" class="text-teal hover:underline">&#8592; Back to Portfolio</a></p>
    </div>
  </section>
</Layout>
